# ---------------------------------------------------------------------------
# Recon Framework configuration.
#
# Copy this file to `.env` and fill in the values you have. NEVER commit your
# real `.env` — it is already listed in .gitignore. Any key you leave blank
# simply causes its collector to be SKIPPED (not an error), so you can start
# with none and add them over time.
# ---------------------------------------------------------------------------

# VirusTotal API key — https://www.virustotal.com/gui/my-apikey (free tier available)
VT_API_KEY=

# Shodan API key — https://account.shodan.io
SHODAN_API_KEY=

# Censys API credentials — https://search.censys.io/account/api  (reserved for future collector)
CENSYS_API_ID=
CENSYS_API_SECRET=

# ---- Behavioural tuning (optional; sensible defaults shown) ----------------
# RECON_TIMEOUT=15         # per-request timeout in seconds
# RECON_RATE_LIMIT=1.0     # polite delay between outbound requests, seconds
# RECON_MAX_RETRIES=2      # retries on transient HTTP failures
# RECON_USER_AGENT=recon-framework/1.0
